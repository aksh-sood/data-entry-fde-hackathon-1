        lines {
          text: "  // Calculate unique months for reports tab"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const getMonthlyBreakdown = () => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const monthsGroup: Record<string, { total: number; count: number; categories: Record<string, number> }> = {};"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    receipts.forEach((r) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const monthKey = r.date.substring(0, 7); // \"YYYY-MM\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (!monthsGroup[monthKey]) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        monthsGroup[monthKey] = { total: 0, count: 0, categories: {} };"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      monthsGroup[monthKey].total += r.amount;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      monthsGroup[monthKey].count += 1;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      monthsGroup[monthKey].categories[r.category] = (monthsGroup[monthKey].categories[r.category] || 0) + r.amount;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    });"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return Object.entries(monthsGroup).sort((a, b) => b[0].localeCompare(a[0]));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  };"
