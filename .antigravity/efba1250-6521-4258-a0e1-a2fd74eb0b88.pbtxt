          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      r.id.toLowerCase().includes(searchQuery.toLowerCase());"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const matchesCategory = categoryFilter === \"All\" || r.category === categoryFilter;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const matchesStatus ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      statusFilter === \"All\" ||"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (statusFilter === \"synced\" && r.status === \"synced\") ||"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (statusFilter === \"pending\" && (r.status === \"pending\" || r.status === \"failed\"));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return matchesSearch && matchesCategory && matchesStatus;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
